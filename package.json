{
  "name": "xfyun-coding-proxy",
  "version": "0.0.1-alpha",
  "description": "Local proxy for iFlytek Xingchen Coding Plan API (OpenAI-compatible)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "xfyun-coding-proxy": "dist/index.js"
  },
  "files": [
    "dist/",
    ".env.example",
    "CHANGELOG.md",
    "docs/README.zh-CN.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/WillieChan2015/xfyun-coding-proxy.git"
  },
  "author": "Willie",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "prepublishOnly": "pnpm test && pnpm build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "keywords": [
    "proxy",
    "xfyun",
    "xf",
    "xunfei",
    "讯飞",
    "MaaS",
    "Astron",
    "astroncodingplan",
    "astron-coding-plan",
    "coding-plan",
    "openai-compatible"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/one-line-logger": "^2.1.0",
    "bun": "^1.3.13",
    "commander": "^14.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "pino-roll": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^20",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
