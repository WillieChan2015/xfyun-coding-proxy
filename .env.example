# 讯飞星辰 Coding Plan 代理服务配置
#
# 全局安装用户推荐将此文件放到：
#   ~/.config/xfyun-coding-proxy/config.env
# 或通过 XFYUN_CODING_PROXY_CONFIG 环境变量指定路径

# 代理服务监听端口
PORT=3000

# 讯飞 Coding Plan API Key（必填，从套餐订阅页复制）
XFYUN_API_KEY=your_coding_plan_api_key_here

# 讯飞 API Base URL（OpenAI 协议端点）
XFYUN_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2

# 最大重试次数（429/503 自动重试）
MAX_RETRIES=3

# 初始重试延迟（毫秒），指数退避
RETRY_DELAY_MS=1000

# 日志输出目录（开发时设为 ./logs，全局安装时默认写入 ~/.local/state/xfyun-coding-proxy/logs）
# XFYUN_LOG_DIR=./logs
