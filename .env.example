# 讯飞星辰 Coding Plan 代理服务配置
#
# 全局安装用户推荐将此文件放到：
#   ~/.config/maas-coding-proxy/config.env
# 或通过 MAAS_CODING_PROXY_CONFIG 环境变量指定路径

# 代理服务监听端口
PORT=3000

# 讯飞 Coding Plan API Key（必填，从套餐订阅页复制）
XFYUN_API_KEY=your_coding_plan_api_key_here

# 讯飞 API Base URL（OpenAI 协议端点）
XFYUN_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2

# 讯飞 Anthropic 协议端点 Base URL
XFYUN_ANTHROPIC_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/anthropic

# 最大重试次数（429/503 自动重试）
MAX_RETRIES=3

# 初始重试延迟（毫秒），指数退避
RETRY_DELAY_MS=1000

# 日志输出目录（开发时设为 ./logs，全局安装时默认写入 ~/.local/state/maas-coding-proxy/logs）
# XFYUN_LOG_DIR=./logs

# 每日统计刷盘间隔（毫秒），设为 0 关闭定时刷盘
# STATS_FLUSH_INTERVAL_MS=60000

# 流式 SSE 单次 read 超时（毫秒），默认 60000
# 上游在流中间停止发送数据时，reader.read() 会无限挂起；
# 此超时防止阻塞，大 context 请求可适当调大（如 120000）
# STREAM_READ_TIMEOUT_MS=60000

# 上游 fetch 总超时（毫秒），默认 300000（5 分钟）
# 从 fetch 调用时刻开始计算的绝对时间限制，包括连接建立 + 流式传输全过程；
# 深度推理/长代码生成等场景可能需要较长时间，可适当调大
# UPSTREAM_FETCH_TIMEOUT_MS=300000

# Debug 模式：开启后记录完整请求/响应数据到日志目录下的 debug/ 子目录（NDJSON 格式）
# 仅用于排查问题，生产环境不应长期开启（日志包含完整 body 和 headers）
# DEBUG_PROXY=1
